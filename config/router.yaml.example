# GTI Router - Archivo de Configuración


device:
  id: "router-node-001"
  name: "Router Principal Norte"

# Coordenadas de instalación (para el mapa 3D de GTI Satélites)
gps:
  lat: 19.4326
  lon: -99.1332
  altitude: 2240.0

# Configuración de Segmentación de Video
hls:
  segment_duration: 4  # Duración de cada segmento en segundos (2 a 8)
  buffer_hours: 4      # Horas de video a guardar si se cae el internet
  backlog_ratio: 3     # Por cada segmento viejo, cuántos nuevos subir

aws:
  bucket: "gti-video-bucket"
  region: "us-east-1"
  # Las credenciales de AWS no van aquí, se leerán como variables de entorno por seguridad

supabase:
  url: "https://tu-proyecto.supabase.co"
  # La clave anónima (anon_key) irá en variables de entorno

# Lista de cámaras conectadas (Soporta IP y Capturadora)
cameras:
  - camera_id: "cam-ip-01"
    input_type: "rtsp_ip"
    url: "rtsp://usuario:password@192.168.1.100:554/stream1"
    orientation:
      azimuth: 45.0
      tilt: -15.0
      fov: 90.0
      mount_height: 5.0

  - camera_id: "cam-hdmi-02"
    input_type: "capture_card"
    device_path: "/dev/video0" # Puerto de la capturadora en la Raspberry
    orientation:
      azimuth: 180.0
      tilt: 0.0
      fov: 60.0
      mount_height: 2.0
